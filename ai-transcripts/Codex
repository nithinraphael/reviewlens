export type ReviewRecord = {
id: string
reviewText: string
rating?: number
product?: string
createdAt?: string
}

export type GuardedAnswer =
| { status: 'ok'; answer: string }
| { status: 'refused'; answer: string; reason: string }

export type LlmClient = {
generate(input: {
system: string
user: string
context: string
temperature?: number
}): Promise<string>
}

/\*\*

- ***
- Config (tune for production)
- ***
  \*/
  const MAX_QUERY_CHARS = 500
  const MAX_REVIEWS = 250
  const MAX_REVIEW_CHARS = 1500
  const SCOPE_SAMPLE_REVIEWS = 50
  const ANSWER_MAX_CHARS = 2500

/\*\*

- sanitize_context(dataset)
- Ensures only review data is passed forward.
- - strips unknown fields
- - normalizes strings
- - caps sizes
- - removes empty reviews
    \*/
    export function sanitize_context(dataset: ReviewRecord[]): ReviewRecord[] {
    if (!Array.isArray(dataset)) return []

return dataset
.slice(0, MAX_REVIEWS)
.map((r) => ({
id: String(r?.id ?? '').trim(),
reviewText: String(r?.reviewText ?? '').trim().slice(0, MAX_REVIEW_CHARS),
rating: typeof r?.rating === 'number' ? r.rating : undefined,
product: r?.product ? String(r.product).trim().slice(0, 120) : undefined,
createdAt: r?.createdAt ? String(r.createdAt).trim().slice(0, 40) : undefined,
}))
.filter((r) => r.id.length > 0 && r.reviewText.length > 0)
}

/\*\*

- generate_refusal_response()
- Standard refusal for all blocked scenarios.
  \*/
  export function generate_refusal_response(): GuardedAnswer {
  return {
  status: 'refused',
  reason: 'OUT_OF_SCOPE_OR_UNSAFE',
  answer:
  'I can only answer questions strictly based on the provided review dataset. Please ask about review content, ratings, sentiment, themes, or products present in those reviews.',
  }
  }

/\*\*

- Basic input safety validation.
- No package dependency, fail-closed approach.
  \*/
  function validate_user_input(query: string): { ok: true } | { ok: false; reason: string } {
  if (typeof query !== 'string') return { ok: false, reason: 'QUERY_NOT_STRING' }

const q = query.trim()
if (!q) return { ok: false, reason: 'QUERY_EMPTY' }
if (q.length > MAX_QUERY_CHARS) return { ok: false, reason: 'QUERY_TOO_LONG' }

// Minimal high-risk prompt-injection / exfiltration indicators
const blockedPatterns: RegExp[] = [
/ignore\s+previous\s+instructions/i,
/reveal\s+(your|the)\s+(system|hidden)\s+prompt/i,
/developer\s+message/i,
/print\s+the\s+full\s+context/i,
/show\s+all\s+raw\s+reviews/i,
/act\s+as\s+an?\s+unrestricted/i,
/bypass\s+(safety|guardrails|policy)/i,
]

if (blockedPatterns.some((p) => p.test(q))) {
return { ok: false, reason: 'QUERY_UNSAFE' }
}

return { ok: true }
}

/\*\*

- Conservative ambiguity detector.
- If short/vague and not clearly review-grounded, reject.
  \*/
  function is_ambiguous_query(query: string): boolean {
  const q = query.trim().toLowerCase()

// very short vague questions
if (q.split(/\s+/).length < 4) return true

const vagueOnly = [
'what about it',
'is it good',
'tell me more',
'what do you think',
'summarize',
]
if (vagueOnly.includes(q)) return true

return false
}

/\*\*

- Check if answer includes citations like [review_id=...]
  \*/
  function has_review_citation(answer: string): boolean {
  return /\[review_id=[^\]]+\]/i.test(answer)
  }

/\*\*

- Heuristic external-knowledge detector.
- Blocks confident world-fact style claims without review references.
  \*/
  function looks_like_external_knowledge(answer: string): boolean {
  const externalSignals = [
  /\baccording to (research|studies|wikipedia|news)\b/i,
  /\bglobally\b/i,
  /\bindustry standard\b/i,
  /\bthe company\b/i,
  /\bmarket share\b/i,
  ]
  return externalSignals.some((r) => r.test(answer))
  }

/\*\*

- is_query_in_scope(query, dataset)
- Strictly about ingested reviews only.
- If ambiguous -> false
- If unsafe -> false
  \*/
  export async function is_query_in_scope(
  query: string,
  dataset: ReviewRecord[],
  llm: LlmClient
  ): Promise<boolean> {
  const inputCheck = validate_user_input(query)
  if (!inputCheck.ok) return false

if (is_ambiguous_query(query)) return false

const clean = sanitize_context(dataset)
if (clean.length === 0) return false

// Build bounded sample for scope classification
const reviewSample = clean
.slice(0, SCOPE_SAMPLE_REVIEWS)
.map((r) => [review_id=${r.id}] ${r.reviewText})
.join('\n')

const system = [
'You are a strict binary classifier for a review-grounded QA system.',
'Task: decide if the QUERY can be answered ONLY from the provided REVIEWS.',
'Return exactly one token: IN_SCOPE or OUT_OF_SCOPE.',
'If ambiguous, underspecified, or requires outside knowledge, return OUT_OF_SCOPE.',
'Do not output anything else.',
].join(' ')

const user = QUERY:\n${query}\n\nREVIEWS:\n${reviewSample}

let raw: string
try {
raw = await llm.generate({
system,
user,
context: reviewSample,
temperature: 0,
})
} catch {
// fail closed
return false
}

const verdict = raw.trim().toUpperCase()
return verdict === 'IN_SCOPE'
}

/\*\*

- guarded_query(query, dataset)
- Full pipeline:
- 1.  validate input
- 2.  enforce scope
- 3.  run constrained LLM call (review-only context)
- 4.  validate output groundedness
- 5.  refuse on any violation
      \*/
      export async function guarded_query(
      query: string,
      dataset: ReviewRecord[],
      llm: LlmClient
      ): Promise<GuardedAnswer> {
      // 1) Input validation
      const inputCheck = validate_user_input(query)
      if (!inputCheck.ok) return generate_refusal_response()

// 2) Scope gate (must pass before answer generation)
const inScope = await is_query_in_scope(query, dataset, llm)
if (!inScope) return generate_refusal_response()

// 3) Sanitize and constrain context
const clean = sanitize_context(dataset)
if (clean.length === 0) return generate_refusal_response()

const context = clean
.map(
(r) =>
